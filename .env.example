# IMAP to Gmail Migration Toolkit - Configuration
# Copy this file to .env and edit with your values.
# This file is loaded by launch_triple_terminal.sh and other scripts.

# Source IMAP server (REQUIRED - change this to your mail server)
SRC_HOST=mail.yourdomain.com

# Destination (usually imap.gmail.com)
DST_HOST=imap.gmail.com

# Performance tuning (defaults work well for 32GB RAM systems)
BUFFER_SIZE=4194304               # 4MB buffer
MAX_BYTES_PER_SECOND=100000       # 100 KB/s (moderate throttle)
MAX_BYTES_AFTER=300000000         # Throttle after 300 MB transferred
MAX_MSGS_PER_SECOND=2             # Messages per second limit
RECONNECT_RETRY=20                # Reconnect attempts per side

# Docker settings (macOS only - auto-detected)
DOCKER_MEMORY_LIMIT=8g           # Container memory ceiling
DOCKER_IMAGE=gilleslamiral/imapsync

# Watchdog settings
MEMORY_LIMIT_MB=40960             # 40GB RSS threshold for process recycling

# Uncomment to force Docker mode (auto-detected on macOS)
# USE_DOCKER=true
